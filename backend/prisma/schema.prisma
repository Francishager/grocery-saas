// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id       String  @id @default(cuid())
  name     String
  address  String?
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  users UserBranch[]
  products Product[]
  accounts Account[]
  sales Sale[]
  purchases Purchase[]
  customers Customer[]
  saleRecords SaleRecord[]
  customerPayments CustomerPayment[]
  invoices Invoice[]
  suppliers Supplier[]
  supplierPurchases SupplierPurchase[]
  supplierPayments SupplierPayment[]
  expenses Expense[]
  rentals  Rental[]
  saleReturns      SaleReturn[]
  journalEntries   JournalEntry[]
  employees        Employee[]
  stockTransfersFrom StockTransfer[] @relation("TransferFrom")
  stockTransfersTo   StockTransfer[] @relation("TransferTo")
  restaurantTables   RestaurantTable[]
  restaurantOrders   RestaurantOrder[]
  reservations       Reservation[]
  fuelPumps          FuelPump[]
  fuelTanks          FuelTank[]
  fuelDeliveries     FuelDelivery[]
  fuelShiftReports   FuelShiftReport[]
  fuelDipstickReadings FuelDipstickReading[]
  fuelPricing        FuelPricing[]
  fuelCompliance     FuelCompliance[]
  productionOrders   ProductionOrder[]
  farmFields         FarmField[]
  livestock          Livestock[]
  harvests           Harvest[]
  farmExpenses       FarmExpense[]
  appointments       Appointment[]
  workOrders         WorkOrder[]
  serviceContracts   ServiceContract[]
  serviceJobCards    ServiceJobCard[]
  serviceFeedback    ServiceFeedback[]
  serviceTechnicians ServiceTechnician[]
  assets             Asset[]
  fuelCards          FuelCard[]
  fuelCardTransactions FuelCardTransaction[]
  taxPayments        TaxPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("branches")
}

model UserBranch {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@map("user_branches")
}

// Tenant/Business - each business is a tenant in the SaaS
model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  email       String       @unique
  phone       String?
  address     String?
  logo        String?
  status      TenantStatus @default(active)
  businessType String?     // retail, pharmacy, hardware, supermarket, wholesale, restaurant, bar, restaurant_bar, cafe, coffee_shop, fast_food, hotel_restaurant, bakery, service, salon_spa, repair_shop, manufacturing, other

  // =====================
  // PLAN RELATION
  // =====================
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  // =====================
  // SUBSCRIPTION PERIOD
  // =====================
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  trialEndsAt       DateTime?

  // =====================
  // OWNERSHIP (1-1)
  // =====================
  ownerId String? @unique
  owner   User?   @relation("TenantOwner", fields: [ownerId], references: [id])

  // =====================
  // USERS (1-MANY)
  // =====================
  users User[] @relation("TenantUsers")

  // =====================
  // BRANCHES
  // =====================
  branches Branch[]

  // =====================
  // INVITATIONS
  // =====================
  invitations Invitation[]

  // =====================
  // BUSINESS DATA
  // =====================
  customers        Customer[]
  suppliers        Supplier[]
  features         TenantFeature[]
  cashAccounts     CashAccount[]
  expenses         Expense[]
  cashTransactions CashTransaction[]
  rentals          Rental[]
  saleReturns      SaleReturn[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  employees        Employee[]
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  payrollRecords   PayrollRecord[]
  stockTransfers   StockTransfer[]
  notifications    Notification[]
  pushTokens       PushToken[]
  integrations     IntegrationConfig[]
  restaurantTables     RestaurantTable[]
  restaurantOrders     RestaurantOrder[]
  reservations         Reservation[]
  recipes              Recipe[]
  waiters              Waiter[]
  happyHourRules       HappyHourRule[]
  comboMeals           ComboMeal[]
  deliveries           Delivery[]

  // =====================
  // FUEL STATION
  // =====================
  fuelPumps        FuelPump[]
  fuelTanks        FuelTank[]
  fuelDeliveries   FuelDelivery[]
  fuelMeterReadings FuelMeterReading[]
  fuelShiftReports  FuelShiftReport[]
  fuelDipstickReadings FuelDipstickReading[]
  fuelPricing        FuelPricing[]
  fuelCompliance     FuelCompliance[]

  // =====================
  // MANUFACTURING
  // =====================
  productionOrders  ProductionOrder[]
  productionWaste   ProductionWaste[]
  qualityChecks     QualityCheck[]
  productionBatches ProductionBatch[]

  // =====================
  // AGRICULTURE
  // =====================
  farmFields        FarmField[]
  livestock         Livestock[]
  harvests          Harvest[]
  farmExpenses      FarmExpense[]

  // =====================
  // SERVICE ENGINE
  // =====================
  appointments      Appointment[]
  workOrders        WorkOrder[]
  serviceContracts  ServiceContract[]
  serviceJobCards   ServiceJobCard[]
  serviceFeedback   ServiceFeedback[]
  serviceTechnicians ServiceTechnician[]

  // =====================
  // ASSETS
  // =====================
  assets            Asset[]
  taxPayments       TaxPayment[]

  // =====================
  // REFERRAL SYSTEM
  // =====================
  referralCode         ReferralCode?     @relation("ReferralCodeTenant")
  referralsMade        Referral[]        @relation("ReferrerTenant")
  referredBy           Referral?         @relation("ReferredTenant")
  referralRewards      ReferralReward[]  @relation("ReferralRewardTenant")

  // =====================
  // USAGE LIMIT
  // =====================
  usageLimitId String?
  usageLimit   UsageLimit? @relation(fields: [usageLimitId], references: [id])

  // =====================
  // BUSINESS SETTINGS
  // =====================
  currency      String   @default("UGX")
  timezone      String   @default("Africa/Kampala")
  taxRate       Float    @default(0) // e.g. 18 for 18% VAT
  taxEnabled    Boolean  @default(false) // toggle tax on/off
  taxId         String?  // VAT/GST registration number
  receiptHeader String?  // Custom text at top of receipts
  receiptFooter String?  // Custom text at bottom of receipts

  // =====================
  // MODULE DEFAULTS (based on businessType, overridable by feature control)
  // =====================
  inventoryEnabled  Boolean @default(true)  // On for product-based, off for service-based
  servicesEnabled   Boolean @default(true)  // On for all business types

  // =====================
  // TIMESTAMPS
  // =====================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =====================
  // WIDGET DATA
  // =====================
  stickyNotes       StickyNote[]
  calculatorHistory CalculatorHistory[]

  @@map("tenants")
}

enum TenantStatus {
  active
  suspended
  cancelled
  trial
}

// Item Types - Product (consumable inventory), Service (no inventory), Rental (returnable inventory)
enum ItemType {
  product
  service
  rental
}

// Rental period for hire items
enum RentalPeriod {
  hourly
  daily
  weekly
  weekend
  monthly
  custom
}

// Rental record status
enum RentalStatus {
  active     // Items are out on hire
  returned   // Items have been returned
  overdue    // Past expected return date
  lost       // Item not returned, marked as lost
  cancelled  // Booking cancelled before hire
}

// Condition of rental item
enum ItemCondition {
  good
  fair
  damaged
  broken
}

// Category Types - Product categories or Service categories
enum CategoryType {
  product
  service
  rental
}

// Subscription Plans
model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  price        Float
  currency     String   @default("USD")
  billingCycle String   @default("monthly") // monthly, yearly
  features     Json // Array of feature strings
  maxUsers     Int      @default(5)
  maxProducts  Int      @default(100)
  maxBranches  Int      @default(3)
  maxCustomers Int      @default(100)
  maxSuppliers Int      @default(50)
  isDefault    Boolean  @default(false)
  tenants      Tenant[]
  planFeatures PlanFeature[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("plans")
}

// Users - can be SaaS Admin or tenant users
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  fname    String?
  lname    String?
  phone    String?
  avatar   String?
  role              UserRole              @default(attendant)
  discountPermission DiscountPermission    @default(none)

  // =========================
  // TENANT (many users per tenant)
  // =========================
  tenantId String?
  tenant   Tenant? @relation("TenantUsers", fields: [tenantId], references: [id], onDelete: Cascade)

  // =========================
  // TENANT OWNERSHIP (1 user owns 1 tenant)
  // =========================
  ownedTenant Tenant? @relation("TenantOwner")

  isActive   Boolean   @default(true)
  lastLogin  DateTime?
  otpCode    String?
  otpExpires DateTime?
  hasCompletedOnboarding Boolean @default(false) // Tenant onboarding guide completion status
  onboardingCompletedAt DateTime? // When user completed the onboarding guide
  cashAccountId String? // Assigned cash account for cash handling accountability
  cashAccount   CashAccount? @relation("UserCashAccount", fields: [cashAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================
  // LEGACY RELATIONS
  // =========================
  sales       Sale[]
  purchases   Purchase[]
  invitations Invitation[] @relation("CreatedBy")

  // =========================
  // NEW RELATIONS
  // =========================
  saleRecords       SaleRecord[]
  supplierPurchases SupplierPurchase[]
  expenses          Expense[]
  cashTransactions  CashTransaction[]
  rentals           Rental[]
  saleReturns       SaleReturn[]
  journalEntries    JournalEntry[]
  stockTransfers    StockTransfer[]
  notifications     Notification[]
  pushTokens        PushToken[]
  restaurantOrders  RestaurantOrder[]
  tips              Tip[]
  fuelShiftReports  FuelShiftReport[]
  productionOrders  ProductionOrder[]
  qualityChecks     QualityCheck[]
  serviceTechnicianProfiles ServiceTechnician[]
  appointmentTechnician Appointment[] @relation("AppointmentTechnician")
  workOrderTechnician   WorkOrder[]   @relation("WorkOrderTechnician")

  // =========================
  // BRANCH ASSIGNMENTS
  // =========================
  branches UserBranch[]
  permissions UserPermission[]
  stickyNotes StickyNote[]
  calculatorHistory CalculatorHistory[]

  @@map("users")
}

enum UserRole {
  saas_admin // Platform admin
  owner // Business owner
  manager // Business manager
  accountant // Business accountant
  attendant // Sales attendant
}

enum DiscountPermission {
  none // Cannot give discounts
  lineItem // Can give line item discounts
  invoice // Can give invoice-level discounts
  managerApproval // Requires manager approval for discounts
}

// Granular user permissions
model UserPermission {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Dashboard
  canViewDashboard Boolean @default(true)
  // Sales
  canCreateSale Boolean @default(true)
  canViewSale   Boolean @default(true)
  canEditSale   Boolean @default(false)
  canDeleteSale Boolean @default(false)
  canRefundSale Boolean @default(false)
  // Inventory
  canCreateProduct Boolean @default(false)
  canViewProduct   Boolean @default(true)
  canEditProduct   Boolean @default(false)
  canDeleteProduct Boolean @default(false)
  canAdjustStock   Boolean @default(false)
  canTransferStock Boolean @default(false)
  // Purchases / Payables
  canCreatePurchase Boolean @default(false)
  canViewPurchase   Boolean @default(true)
  canEditPurchase   Boolean @default(false)
  canDeletePurchase Boolean @default(false)
  canCreatePayable  Boolean @default(false)
  canViewPayable    Boolean @default(true)
  canEditPayable    Boolean @default(false)
  canDeletePayable  Boolean @default(false)
  // Expenses
  canCreateExpense Boolean @default(false)
  canViewExpense   Boolean @default(true)
  canEditExpense   Boolean @default(false)
  canDeleteExpense Boolean @default(false)
  canViewStaffTillSheet Boolean @default(false)
  // Customers / Receivables
  canCreateCustomer Boolean @default(false)
  canViewCustomer   Boolean @default(true)
  canEditCustomer   Boolean @default(false)
  canDeleteCustomer Boolean @default(false)
  canCreateReceivable Boolean @default(false)
  canViewReceivable   Boolean @default(true)
  canEditReceivable   Boolean @default(false)
  canDeleteReceivable Boolean @default(false)
  // Suppliers
  canCreateSupplier Boolean @default(false)
  canViewSupplier   Boolean @default(true)
  canEditSupplier   Boolean @default(false)
  canDeleteSupplier Boolean @default(false)
  // Staff
  canCreateStaff Boolean @default(false)
  canViewStaff   Boolean @default(true)
  canEditStaff   Boolean @default(false)
  canDeleteStaff Boolean @default(false)
  // Branches
  canCreateBranch Boolean @default(false)
  canViewBranch   Boolean @default(true)
  canEditBranch   Boolean @default(false)
  canDeleteBranch Boolean @default(false)
  // Reports (granular)
  canViewSalesReport      Boolean @default(true)
  canViewInventoryReport  Boolean @default(true)
  canViewFinancialReport  Boolean @default(true)
  canViewCustomerReport   Boolean @default(true)
  canViewSupplierReport   Boolean @default(true)
  canViewReceivablesReport Boolean @default(true)
  canViewPayablesReport   Boolean @default(true)
  canViewPerformanceReport Boolean @default(true)
  canViewAuditReport      Boolean @default(true)
  canExportReport         Boolean @default(false)
  // Settings
  canViewSettings   Boolean @default(true)
  canEditSettings   Boolean @default(false)
  // Receipts
  canViewReceipt   Boolean @default(true)
  canCreateReceipt Boolean @default(false)
  // Discounts
  canGiveDiscount Boolean @default(false)
  // Tax
  canViewTax   Boolean @default(true)
  canManageTax Boolean @default(false)
  // Services
  canViewService       Boolean @default(true)
  canCreateService     Boolean @default(false)
  canEditService       Boolean @default(false)
  canDeleteService     Boolean @default(false)
  canManageServiceCategory Boolean @default(false)
  canViewServiceReport Boolean @default(true)
  // Rentals / Hire
  canViewRental       Boolean @default(true)
  canCreateRental     Boolean @default(false)
  canEditRental       Boolean @default(false)
  canDeleteRental     Boolean @default(false)
  canProcessRentalReturn Boolean @default(false)
  canViewRentalReport Boolean @default(true)
  // Restaurant & Bar
  canViewRestaurant       Boolean @default(false)
  canCreateRestaurant     Boolean @default(false)
  canEditRestaurant       Boolean @default(false)
  canDeleteRestaurant     Boolean @default(false)
  canViewRestaurantReport Boolean @default(false)
  // Fuel Station
  canViewFuelStation       Boolean @default(false)
  canCreateFuelStation     Boolean @default(false)
  canEditFuelStation       Boolean @default(false)
  canDeleteFuelStation     Boolean @default(false)
  canViewFuelStationReport Boolean @default(false)
  // Manufacturing
  canViewManufacturing       Boolean @default(false)
  canCreateManufacturing     Boolean @default(false)
  canEditManufacturing       Boolean @default(false)
  canDeleteManufacturing     Boolean @default(false)
  canViewManufacturingReport Boolean @default(false)
  // Agriculture
  canViewAgriculture       Boolean @default(false)
  canCreateAgriculture     Boolean @default(false)
  canEditAgriculture       Boolean @default(false)
  canDeleteAgriculture     Boolean @default(false)
  canViewAgricultureReport Boolean @default(false)
  // Service Business (appointments, work orders, contracts)
  canViewServiceBusiness       Boolean @default(false)
  canCreateServiceBusiness     Boolean @default(false)
  canEditServiceBusiness       Boolean @default(false)
  canDeleteServiceBusiness     Boolean @default(false)
  canViewServiceBusinessReport Boolean @default(false)
  // Communication
  canViewCommunication   Boolean @default(false)
  canCreateCommunication Boolean @default(false)
  canEditCommunication   Boolean @default(false)
  canDeleteCommunication Boolean @default(false)
  // Accounting
  canViewAccounting   Boolean @default(false)
  canCreateAccounting Boolean @default(false)
  canEditAccounting   Boolean @default(false)
  canDeleteAccounting Boolean @default(false)
  // Payment Methods (for spending — expenses, payables)
  canUseCash        Boolean @default(true)
  canUseMobileMoney Boolean @default(false)
  canUseBank        Boolean @default(false)
  canUseCard        Boolean @default(false)
  // Data Import
  canImportInventory Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@map("user_permissions")
}

// Invitations for new business owners
model Invitation {
  id          String           @id @default(cuid())
  email       String
  name        String?
  phone       String?
  token       String           @unique
  otpCode     String? // OTP for verification during acceptance
  status      InvitationStatus @default(pending)
  planId      String?
  message     String?
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  createdById String
  createdBy   User             @relation("CreatedBy", fields: [createdById], references: [id])
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("invitations")
}

enum InvitationStatus {
  pending
  accepted
  expired
  cancelled
}

// Products/Inventory
model Product {
  id          String    @id @default(cuid())
  name        String
  // =====================
  // ITEM TYPE (Product or Service)
  // =====================
  itemType    ItemType  @default(product)
  // Service-specific fields (null for products/rentals)
  serviceCategory String?  // e.g. "IT Services", "Legal Services", "Consulting"
  estimatedHours  Float?   // Estimated duration for service delivery
  duration        String?  // Human-readable duration: "2 hours", "1 week", etc.
  // =====================
  // RENTAL-SPECIFIC FIELDS (null for products/services)
  // =====================
  rentalPrice       Float?      // Hire charge per period (e.g. per day)
  rentalPeriod      RentalPeriod? // Default billing period for this item
  depositAmount     Float?      // Security deposit required
  replacementValue  Float?      // Cost if item is lost/damaged beyond repair
  // =====================
  // PRODUCT FIELDS (ignored for services, used for rental stock tracking)
  // =====================
  sku         String?
  barcode     String?
  batchNumber String?
  description String?
  price       Float
  cost        Float?
  quantity    Int       @default(0)
  minStock    Int       @default(10)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  isUncategorized Boolean @default(false)
  tenantId    String
  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive    Boolean   @default(true)
  image       String?
  expiryDate  DateTime?
  baseUnit    String    @default("Piece") // Base unit of measure: KG, Bottle, Piece, Tablet, etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Legacy relations (keep for compatibility)
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]

  // New relations
  saleRecordItems       SaleRecordItem[]
  supplierPurchaseItems SupplierPurchaseItem[]
  units                 ProductUnit[]
  rentalItems           RentalItem[]
  saleReturnItems       SaleReturnItem[]
  stockTransferItems    StockTransferItem[]
  recipeIngredients     RecipeIngredient[]
  comboMealItems        ComboMealItem[]
  orderItems            RestaurantOrderItem[]
  recipes               Recipe[]
  productionOrders      ProductionOrder[]
  productionWaste       ProductionWaste[]
  productionBatches     ProductionBatch[]
  harvests              Harvest[]
  appointmentProducts   Appointment[]
  workOrderProducts     WorkOrder[]

  @@unique([tenantId, branchId, sku])
  @@unique([tenantId, branchId, barcode])
  @@index([tenantId, branchId])
  @@map("products")
}

// Product Selling Units (Multi-UOM)
model ProductUnit {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitName       String   // e.g. "Quarter KG", "Pack", "Crate"
  conversionFactor Float  // e.g. 0.25, 6, 24 — how many base units in this selling unit
  sellingPrice   Float    // Price for this unit
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productId, unitName])
  @@map("product_units")
}

// Audit Log — tracks all data mutations
model AuditLog {
  id             String   @id @default(cuid())
  tenantId       String   // tenant ID or "platform" for SaaS admin operations
  targetTenantId String?  // which tenant was affected by this operation (for cross-tenant operations)
  userId         String
  userEmail      String
  action         String   // create, update, delete, login, checkout, reset, suspend, enable, disable, etc.
  model          String   // Product, Sale, Purchase, User, Plan, Tenant, Feature, etc.
  recordId       String?  // ID of the affected record
  changes        Json?    // { before: {...}, after: {...} } or { data: {...} }
  ip             String?
  statusCode     Int      @default(200) // HTTP status code
  severity       String   @default("info") // info, warning, critical
  createdAt      DateTime @default(now())

  @@index([tenantId, model])
  @@index([tenantId, createdAt])
  @@index([tenantId, severity])
  @@index([targetTenantId]) // fast lookup of operations affecting a specific tenant
  @@index([severity])
  @@map("audit_logs")
}

// Track tenant usage metrics (daily snapshots)
model TenantMetrics {
  id                  String   @id @default(cuid())
  tenantId            String
  date                DateTime @default(now())
  activeUsers         Int      @default(0)
  totalUsers          Int      @default(0)
  totalProducts       Int      @default(0)
  totalSales          Int      @default(0)
  totalSalesAmount    Float    @default(0)
  featuresUsed        String[] @default([]) // array of feature keys used
  lastActivityAt      DateTime?
  createdAt           DateTime @default(now())

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([date])
  @@map("tenant_metrics")
}

// Track individual tenant operations/activity
model TenantActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  userEmail String
  action    String   // login, create_product, create_sale, view_report, etc.
  model     String   // Product, Sale, User, Report, etc.
  recordId  String?
  details   Json?    // additional context specific to the activity
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, userId])
  @@map("tenant_activity_logs")
}

// Categories
model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String
  tenantId      String
  categoryType  CategoryType  @default(product) // product or service
  products      Product[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, slug])
  @@map("categories")
}

// Sales/Orders
model Sale {
  id            String     @id @default(cuid())
  receiptNo     String
  tenantId      String
  branchId      String?
  branch        Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  total         Float
  subtotal      Float
  tax           Float      @default(0)
  discount      Float      @default(0)
  cashDiscount  Float      @default(0) // Invoice-level cash discount
  paymentMethod String
  mobileProvider String?
  phoneNumber    String?
  transactionId  String?
  amountPaid     Float?     // Amount customer paid (for cash change calculation)
  changeGiven    Float?     // Change given back to customer
  status        SaleStatus @default(completed)
  notes         String?
  items         SaleItem[]
  saleReturns   SaleReturn[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([tenantId, receiptNo])
  @@index([tenantId, branchId])
  @@map("sales")
}

enum SaleStatus {
  pending
  completed
  cancelled
  refunded
}

// Sale Items
model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  discount         Float    @default(0)
  cashDiscount     Float    @default(0) // Cash discount amount on this line item
  unitName         String?  // Selling unit name (e.g. "Half KG", "Pack")
  conversionFactor Float?   // Conversion factor used at time of sale
  total     Float
  createdAt DateTime @default(now())

  @@map("sale_items")
}

// Purchases
model Purchase {
  id            String         @id @default(cuid())
  refNo         String?
  tenantId      String
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  supplier      String?
  paymentMethod String?        @default("cash")
  total         Float
  notes         String?
  items         PurchaseItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId, branchId])
  @@map("purchases")
}

// Purchase Items
model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  cost       Float
  total      Float
  createdAt  DateTime @default(now())

  @@map("purchase_items")
}

// =====================================================
// RECEIVABLES - Customer Credit System
// =====================================================

// Customers
model Customer {
  id          String         @id @default(cuid())
  name        String
  email       String?
  phone       String?
  nin         String?
  address     String?
  tenantId    String
  branchId    String?
  branch      Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  creditLimit Float          @default(0)
  balance     Float          @default(0) // Current outstanding balance
  status      CustomerStatus @default(active)
  trustScore  Int            @default(50) // 0-100, affects credit eligibility
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sales    SaleRecord[]
  payments CustomerPayment[]
  invoices Invoice[]
  rentals  Rental[]
  saleReturns SaleReturn[]
  reservations Reservation[]
  deliveries   Delivery[]
  restaurantOrders RestaurantOrder[]
  appointments Appointment[]
  workOrders   WorkOrder[]
  serviceContracts ServiceContract[]
  serviceFeedback ServiceFeedback[]
  fuelCards        FuelCard[]
  Tenant   Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, branchId, phone])
  @@index([tenantId, branchId])
  @@map("customers")
}

enum CustomerStatus {
  active
  inactive
  blocked
}

// Sales Records (includes credit sales)
model SaleRecord {
  id            String            @id @default(cuid())
  receiptNo     String
  tenantId      String
  branchId      String?
  branch        Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer?         @relation(fields: [customerId], references: [id])
  userId        String
  total         Float
  subtotal      Float
  tax           Float             @default(0)
  discount      Float             @default(0)
  cashDiscount  Float             @default(0) // Invoice-level cash discount
  amountPaid    Float             @default(0)
  balance       Float             @default(0) // Remaining balance for credit sales
  paymentMethod String
  paymentStatus PaymentStatus     @default(paid)
  status        SaleRecordStatus  @default(completed)
  dueDate       DateTime?
  notes         String?
  items         SaleRecordItem[]
  payments      CustomerPayment[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  User          User              @relation(fields: [userId], references: [id])

  @@unique([tenantId, receiptNo])
  @@index([tenantId, branchId])
  @@map("sale_records")
}

enum PaymentStatus {
  paid // Fully paid
  partial // Partially paid
  unpaid // Not paid at all (credit sale)
  overdue // Past due date
}

enum SaleRecordStatus {
  pending
  completed
  cancelled
  refunded
}

// Sale Record Items
model SaleRecordItem {
  id        String     @id @default(cuid())
  saleId    String
  sale      SaleRecord @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  discount         Float      @default(0)
  cashDiscount     Float      @default(0) // Cash discount on this line item
  unitName         String?    // Selling unit name
  conversionFactor Float?     // Conversion factor used at time of sale
  total     Float
  createdAt DateTime   @default(now())

  @@map("sale_record_items")
}

// Customer Payments
model CustomerPayment {
  id            String      @id @default(cuid())
  tenantId      String
  branchId      String?
  branch        Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  saleId        String?
  sale          SaleRecord? @relation(fields: [saleId], references: [id])
  amount        Float
  paymentMethod  String // cash, mobile_money, bank_transfer
  mobileProvider String?
  phoneNumber    String?
  transactionId  String?
  reference      String? // Transaction reference
  notes          String?
  createdAt     DateTime    @default(now())

  @@index([tenantId, branchId])
  @@map("customer_payments")
}

// Invoices
model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String
  tenantId   String
  branchId   String?
  branch     Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  saleId     String?
  total      Float
  amountPaid Float         @default(0)
  balance    Float
  status     InvoiceStatus @default(unpaid)
  dueDate    DateTime
  sentAt     DateTime?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, branchId])
  @@map("invoices")
}

enum InvoiceStatus {
  draft
  sent
  unpaid
  partial
  paid
  cancelled
  overdue
}

// Fuel Cards - Prepaid/credit cards issued by fuel station
model FuelCard {
  id          String       @id @default(cuid())
  cardNumber  String
  tenantId    String
  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId  String?
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  holderName  String
  cardType    FuelCardType @default(prepaid)
  balance     Float        @default(0)
  creditLimit Float        @default(0)
  status      FuelCardStatus @default(active)
  issuedAt    DateTime     @default(now())
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  transactions FuelCardTransaction[]

  @@unique([tenantId, cardNumber])
  @@index([tenantId, branchId])
  @@map("fuel_cards")
}

enum FuelCardType {
  prepaid
  credit
  fleet
}

enum FuelCardStatus {
  active
  suspended
  expired
  cancelled
}

model FuelCardTransaction {
  id          String   @id @default(cuid())
  cardId      String
  card        FuelCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tenantId    String
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  type        String   // reload, purchase, adjustment
  amount      Float
  balanceAfter Float
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("fuel_card_transactions")
}

// =====================================================
// PAYABLES - Supplier Management
// =====================================================

// Suppliers
model Supplier {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  tenantId  String
  branchId  String?
  branch    Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  balance   Float          @default(0) // Amount owed to supplier
  status    SupplierStatus @default(active)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  purchases SupplierPurchase[]
  payments  SupplierPayment[]
  Tenant    Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, branchId, phone])
  @@index([tenantId, branchId])
  @@map("suppliers")
}

enum SupplierStatus {
  active
  inactive
  blocked
}

// Supplier Purchases
model SupplierPurchase {
  id            String                 @id @default(cuid())
  refNo         String?
  tenantId      String
  branchId      String?
  branch        Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplierId    String
  supplier      Supplier               @relation(fields: [supplierId], references: [id])
  userId        String
  total         Float
  amountPaid    Float                  @default(0)
  balance       Float                  @default(0)
  paymentStatus PaymentStatus          @default(unpaid)
  dueDate       DateTime?
  notes         String?
  items         SupplierPurchaseItem[]
  payments      SupplierPayment[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  User          User                   @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId])
  @@map("supplier_purchases")
}

// Supplier Purchase Items
model SupplierPurchaseItem {
  id         String           @id @default(cuid())
  purchaseId String
  purchase   SupplierPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product          @relation(fields: [productId], references: [id])
  quantity   Int
  cost       Float
  total      Float
  createdAt  DateTime         @default(now())

  @@map("supplier_purchase_items")
}

// Supplier Payments
model SupplierPayment {
  id            String            @id @default(cuid())
  tenantId      String
  branchId      String?
  branch        Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplierId    String
  supplier      Supplier          @relation(fields: [supplierId], references: [id])
  purchaseId    String?
  purchase      SupplierPurchase? @relation(fields: [purchaseId], references: [id])
  amount         Float
  paymentMethod  String
  mobileProvider String?
  phoneNumber    String?
  transactionId  String?
  reference      String?
  notes          String?
  createdAt      DateTime          @default(now())

  @@index([tenantId, branchId])
  @@map("supplier_payments")
}

// =====================================================
// EXPENSES
// =====================================================

model Expense {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category      String // rent, transport, salaries, utilities, etc.
  description   String
  amount         Float
  paymentMethod  String
  cashAccountId String? // Which cash account this expense was paid from
  cashAccount    CashAccount? @relation(fields: [cashAccountId], references: [id], onDelete: SetNull)
  mobileProvider String?
  phoneNumber    String?
  transactionId  String?
  reference      String?
  notes          String?
  userId         String // Who recorded it
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  Tenant        Tenant   @relation(fields: [tenantId], references: [id])
  User          User     @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId])
  @@map("expenses")
}

// =====================================================
// CASH FLOW & ACCOUNTS
// =====================================================

model CashAccount {
  id              String            @id @default(cuid())
  tenantId        String
  name            String // "Cash Box", "MTN Mobile Money", "Stanbic Bank"
  type            String // cash, mobile_money, bank, card
  accountNumber   String? // Phone number for mobile money, account number for bank
  bankName        String? // Bank name (bank type only)
  accountHolder   String? // Name of the account holder
  branchName      String? // Bank branch (bank type only)
  balance         Float             @default(0)
  currency        String            @default("UGX")
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Tenant          Tenant            @relation(fields: [tenantId], references: [id])
  CashTransaction CashTransaction[]
  Expense         Expense[]
  AssignedUsers   User[]            @relation("UserCashAccount")

  @@unique([tenantId, name])
  @@map("cash_accounts")
}

model CashTransaction {
  id           String      @id @default(cuid())
  tenantId     String
  accountId    String
  account      CashAccount @relation(fields: [accountId], references: [id])
  type         String // income, expense, transfer
  amount       Float
  balanceAfter Float
  reference    String? // Sale ID, Purchase ID, etc.
  description  String?
  userId       String
  createdAt    DateTime    @default(now())
  Tenant       Tenant      @relation(fields: [tenantId], references: [id])
  User         User        @relation(fields: [userId], references: [id])

  @@map("cash_transactions")
}

// =====================================================
// FEATURE ACCESS CONTROL
// =====================================================

// System Features
model Feature {
  id          String   @id @default(cuid())
  name        String   @unique // "inventory.products", "sales.returns", "reports.sales", etc.
  displayName String
  description String?
  module      String   @default("core") // "sales", "inventory", "customers", "suppliers", etc.
  category    String // "core", "advanced", "integration", "module"
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  planFeatures   PlanFeature[]
  tenantFeatures TenantFeature[]

  @@map("features")
}

// Plan Features (which features each plan includes)
model PlanFeature {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([planId, featureId])
  @@map("plan_features")
}

// Tenant Feature Overrides (manual overrides per tenant)
model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, featureId])
  @@map("tenant_features")
}

// Usage Limits per Tenant
model UsageLimit {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  maxProducts  Int      @default(100)
  maxUsers     Int      @default(5)
  maxBranches  Int      @default(1)
  maxCustomers Int      @default(100)
  maxSuppliers Int      @default(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Tenant       Tenant[]

  @@map("usage_limits")
}

// =====================================================
// UPDATE EXISTING MODELS
// =====================================================

// Update Product to include new relations
// Update Sale to use SaleRecord instead
// Update Purchase to use SupplierPurchase instead

// =====================================================
// RENTALS - Hire / Rental System
// =====================================================

model Rental {
  id              String       @id @default(cuid())
  rentalNo        String       // e.g. HIRE-1234567890
  tenantId        String
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  userId          String
  User            User         @relation(fields: [userId], references: [id])
  hireDate        DateTime     @default(now())      // When items go out
  expectedReturnDate DateTime                       // When items should come back
  actualReturnDate DateTime?                        // When items actually returned
  totalAmount     Float        @default(0)           // Total hire charge
  depositAmount   Float        @default(0)           // Security deposit collected
  depositStatus   String       @default("collected") // collected, refunded, forfeited
  amountPaid      Float        @default(0)           // Hire charge paid so far
  balance         Float        @default(0)           // Outstanding hire charge
  paymentStatus   String       @default("unpaid")    // paid, partial, unpaid
  paymentMethod   String?      @default("cash")
  mobileProvider  String?
  phoneNumber     String?
  transactionId   String?
  discount        Float        @default(0)
  taxRate         Float        @default(0)
  taxAmount       Float        @default(0)
  guarantorName   String?
  guarantorPhone  String?
  customerNin     String?
  status          RentalStatus @default(active)
  notes           String?
  items           RentalItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  Tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, branchId])
  @@index([customerId])
  @@map("rentals")
}

model RentalItem {
  id              String        @id @default(cuid())
  rentalId        String
  rental          Rental        @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int           @default(1)
  unitHirePrice   Float         @default(0)   // Price per period
  rentalPeriod    RentalPeriod  @default(daily)
  periods         Int           @default(1)   // Number of periods (e.g. 3 days)
  totalAmount     Float         @default(0)   // quantity * unitHirePrice * periods
  conditionOut    ItemCondition @default(good) // Condition when hired out
  conditionReturn ItemCondition?               // Condition when returned (null if not yet returned)
  damageFee       Float?                       // Fee charged if item returned damaged
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([rentalId])
  @@index([productId])
  @@map("rental_items")
}

// =====================================================
// SALE RETURNS & REFUNDS
// =====================================================

model SaleReturn {
  id            String   @id @default(cuid())
  returnNo      String
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  saleId        String?
  sale          Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  total         Float    @default(0)
  reason        String?
  refundMethod  String   @default("cash") // cash, credit, mobile_money
  status        String   @default("completed") // completed, pending
  items         SaleReturnItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, returnNo])
  @@index([tenantId, branchId])
  @@index([saleId])
  @@map("sale_returns")
}

model SaleReturnItem {
  id          String     @id @default(cuid())
  returnId    String
  return      SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float
  total       Float
  reason      String?
  createdAt   DateTime   @default(now())

  @@index([returnId])
  @@map("sale_return_items")
}

// =====================================================
// ACCOUNTING
// =====================================================

model Account {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String   // e.g. "1000", "2001"
  name        String   // e.g. "Cash", "Accounts Receivable"
  type        String   // asset, liability, equity, revenue, expense
  subType     String?  // current_asset, fixed_asset, current_liability, etc.
  parentId    String?
  parent      Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  balance     Float    @default(0)
  isActive    Boolean  @default(true)
  description String?
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  journalLines JournalLine[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accounts")
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNo     String
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  date        DateTime @default(now())
  description String?
  reference   String?  // e.g. sale receipt no, invoice no
  status      String   @default("posted") // draft, posted, reversed
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lines       JournalLine[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, entryNo])
  @@index([tenantId])
  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Float        @default(0)
  credit      Float        @default(0)
  description String?
  createdAt   DateTime     @default(now())

  @@index([entryId])
  @@map("journal_lines")
}

// =====================================================
// HR MANAGEMENT
// =====================================================

model Employee {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  firstName   String
  lastName    String
  email       String?
  phone       String?
  position    String?  // e.g. "Cashier", "Manager"
  department  String?
  salary      Float    @default(0)
  payFrequency String  @default("monthly") // weekly, biweekly, monthly
  hireDate    DateTime @default(now())
  terminationDate DateTime?
  status      String   @default("active") // active, terminated, on_leave
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  payrollRecords PayrollRecord[]

  @@index([tenantId])
  @@map("employees")
}

model Attendance {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  checkIn     DateTime?
  checkOut    DateTime?
  status      String   @default("present") // present, absent, late, half_day, holiday
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([employeeId, date])
  @@index([tenantId, employeeId])
  @@map("attendance")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   String   @default("annual") // annual, sick, casual, maternity
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      String   @default("pending") // pending, approved, rejected
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, employeeId])
  @@map("leave_requests")
}

model PayrollRecord {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period      String   // e.g. "2025-01" for Jan 2025
  grossSalary Float   @default(0)
  deductions  Float   @default(0)
  netSalary   Float   @default(0)
  bonus       Float   @default(0)
  status      String  @default("pending") // pending, paid
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, period])
  @@index([tenantId])
  @@map("payroll_records")
}

// =====================================================
// STOCK TRANSFERS (Branch Transfers)
// =====================================================

model StockTransfer {
  id            String   @id @default(cuid())
  transferNo    String
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromBranchId  String?
  fromBranch    Branch?  @relation("TransferFrom", fields: [fromBranchId], references: [id], onDelete: SetNull)
  toBranchId    String?
  toBranch      Branch?  @relation("TransferTo", fields: [toBranchId], references: [id], onDelete: SetNull)
  status        String   @default("pending") // pending, in_transit, received, cancelled
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  notes         String?
  items         StockTransferItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, transferNo])
  @@index([tenantId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id          String        @id @default(cuid())
  transferId  String
  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  quantity    Int
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([transferId])
  @@map("stock_transfer_items")
}

// =====================================================
// NOTIFICATIONS (Communication)
// =====================================================

model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     String   @default("in_app") // in_app, sms, email, whatsapp
  title       String
  message     String
  type        String   @default("info") // info, warning, success, error
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, userId])
  @@map("notifications")
}

// =====================================================
// INTEGRATION CONFIG
// =====================================================

model IntegrationConfig {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider    String   // stripe, flutterwave, mobile_money, qr_payments
  displayName String
  isActive    Boolean  @default(false)
  credentials Json?    // encrypted credentials
  settings    Json?    // provider-specific settings
  webhookUrl  String?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("integration_configs")
}

// =====================================================
// RESTAURANT MODULE
// =====================================================

// Restaurant Tables
model RestaurantTable {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "Table 1", "VIP 1", "Garden 3"
  capacity    Int      @default(4)
  status      TableStatus @default(available)
  area        String?  // "Main Hall", "Terrace", "Garden", "Bar"
  mergedWith  String?  // ID of table this is merged into
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      RestaurantOrder[]
  reservations Reservation[]

  @@index([tenantId, branchId])
  @@map("restaurant_tables")
}

enum TableStatus {
  available
  occupied
  reserved
  cleaning
}

// Restaurant Orders (Dine-in, Takeaway, Delivery)
model RestaurantOrder {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orderNo       String   // "ORD-001"
  tableId       String?
  table         RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  waiterId      String?
  waiter        Waiter?  @relation(fields: [waiterId], references: [id], onDelete: SetNull)
  userId        String   // who created the order (cashier/waiter)
  user          User     @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderType     OrderType @default(dine_in)
  status        OrderStatus @default(pending)
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  discount      Float    @default(0)
  tipAmount     Float    @default(0)
  total         Float    @default(0)
  specialInstructions String?
  paymentStatus PaymentStatus @default(unpaid)
  paymentMethod String?
  saleId        String?  // linked Sale when completed
  deliveryId    String?  @unique // linked Delivery if delivery order
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         RestaurantOrderItem[]
  tips          Tip[]
  delivery      Delivery?

  @@unique([tenantId, orderNo])
  @@index([tenantId, branchId, status])
  @@map("restaurant_orders")
}

enum OrderType {
  dine_in
  takeaway
  delivery
}

enum OrderStatus {
  pending
  preparing
  ready
  served
  completed
  cancelled
}

// Order Items
model RestaurantOrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int      @default(1)
  price         Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  station       String?  // "kitchen" or "bar" — determines KOT vs BOT
  status        ItemStatus @default(pending)
  specialInstructions String?
  createdAt     DateTime @default(now())

  @@index([orderId])
  @@map("restaurant_order_items")
}

enum ItemStatus {
  pending
  preparing
  ready
  served
  cancelled
}

// Waiters
model Waiter {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  name        String
  phone       String?
  code        String?  // short code for quick assignment
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      RestaurantOrder[]
  tips        Tip[]

  @@index([tenantId])
  @@map("waiters")
}

// Tips
model Tip {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  order       RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  waiterId    String?
  waiter      Waiter?  @relation(fields: [waiterId], references: [id], onDelete: SetNull)
  userId      String   // who recorded the tip
  user        User     @relation(fields: [userId], references: [id])
  amount      Float    @default(0)
  tipType     String   @default("amount") // "amount" or "percentage"
  tipValue    Float?   // percentage value if tipType is percentage
  createdAt   DateTime @default(now())

  @@index([tenantId, orderId])
  @@map("tips")
}

// Reservations
model Reservation {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  tableId       String?
  table         RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  date          DateTime
  time          String   // "19:30"
  guests        Int      @default(1)
  specialRequests String?
  status        ReservationStatus @default(reserved)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, date])
  @@map("reservations")
}

enum ReservationStatus {
  reserved
  checked_in
  cancelled
  completed
}

// Recipes (Bill of Materials)
model Recipe {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String   // the menu item this recipe is for
  product     Product   @relation(fields: [productId], references: [id])
  name        String
  yield       String?  // "1 plate", "2 servings"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients RecipeIngredient[]
  productionOrders ProductionOrder[]

  @@unique([tenantId, productId])
  @@map("recipes")
}

model RecipeIngredient {
  id          String   @id @default(cuid())
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId   String   // the ingredient (inventory item)
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float    @default(0)
  unit        String   @default("Piece") // KG, ML, G, Piece, etc.
  notes       String?

  @@index([recipeId])
  @@map("recipe_ingredients")
}

// Happy Hour Pricing
model HappyHourRule {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  name        String   // "Happy Hour", "Early Bird"
  productId   String?  // null = applies to all, specific product = single item
  startTime   String   // "16:00"
  endTime     String   // "19:00"
  daysOfWeek  String?  // "1,2,3,4,5" (Mon-Fri), null = every day
  discountType String  @default("percentage") // "percentage" or "fixed"
  discountValue Float  @default(0) // 25 = 25% off, or 1500 = UGX 1500 off
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("happy_hour_rules")
}

// Combo Meals
model ComboMeal {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  name        String   // "Lunch Combo"
  description String?
  price       Float    @default(0) // combo selling price
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       ComboMealItem[]

  @@index([tenantId])
  @@map("combo_meals")
}

model ComboMealItem {
  id          String   @id @default(cuid())
  comboMealId String
  comboMeal   ComboMeal @relation(fields: [comboMealId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)

  @@index([comboMealId])
  @@map("combo_meal_items")
}

// Delivery
model Delivery {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId       String?  @unique // linked restaurant order
  order         RestaurantOrder? @relation(fields: [orderId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String
  address       String
  riderName     String?
  riderPhone    String?
  deliveryFee   Float    @default(0)
  status        DeliveryStatus @default(pending)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@map("deliveries")
}

enum DeliveryStatus {
  pending
  on_delivery
  delivered
  cancelled
}

// =====================
// REFERRAL SYSTEM
// =====================

model ReferralCode {
  id        String   @id @default(cuid())
  code      String   @unique
  tenantId  String   @unique
  tenant    Tenant   @relation("ReferralCodeTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  referrals Referral[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("referral_codes")
}

model Referral {
  id              String           @id @default(cuid())
  referralCodeId  String
  referralCode    ReferralCode     @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  referrerTenantId String
  referrerTenant  Tenant           @relation("ReferrerTenant", fields: [referrerTenantId], references: [id], onDelete: Cascade)
  referredTenantId String?  @unique
  referredTenant  Tenant?          @relation("ReferredTenant", fields: [referredTenantId], references: [id], onDelete: SetNull)
  referredEmail   String
  status          ReferralStatus   @default(pending)
  rewardType      ReferralRewardType @default(subscription_discount)
  rewardValue     Float            @default(10) // percentage or months
  rewardStatus    ReferralRewardStatus @default(unclaimed)
  appliedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  reward          ReferralReward?

  @@index([referrerTenantId])
  @@index([status])
  @@map("referrals")
}

model ReferralReward {
  id          String   @id @default(cuid())
  referralId  String   @unique
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation("ReferralRewardTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  type        ReferralRewardType @default(subscription_discount)
  value       Float
  description String?
  claimedAt   DateTime @default(now())

  @@map("referral_rewards")
}

enum ReferralStatus {
  pending
  invited
  signed_up
  subscribed
  completed
  expired
  cancelled
}

enum ReferralRewardType {
  subscription_discount
  free_months
  credit
  feature_unlock
}

enum ReferralRewardStatus {
  unclaimed
  claimed
  expired
}

// =====================================================
// FUEL STATION MODULE
// =====================================================

model FuelPump {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "Pump 1", "Pump 2"
  tankId      String?
  tank        FuelTank? @relation(fields: [tankId], references: [id], onDelete: SetNull)
  nozzleCount Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meterReadings FuelMeterReading[]
  shiftReports  FuelShiftReport[]

  @@index([tenantId, branchId])
  @@map("fuel_pumps")
}

model FuelTank {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name          String   // "Tank 1 - Petrol", "Tank 2 - Diesel"
  fuelType      String   // petrol, diesel, kerosene, gas
  capacity      Float    @default(0) // litres
  currentStock  Float    @default(0) // litres
  unitCost      Float    @default(0) // cost per litre
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pumps       FuelPump[]
  deliveries  FuelDelivery[]
  dipstickReadings FuelDipstickReading[]

  @@index([tenantId, branchId])
  @@map("fuel_tanks")
}

model FuelDelivery {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  tankId        String
  tank          FuelTank @relation(fields: [tankId], references: [id])
  supplierName  String?
  invoiceNo     String?
  litres        Float
  unitCost      Float
  totalCost     Float
  deliveryDate  DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("fuel_deliveries")
}

model FuelMeterReading {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pumpId      String
  pump        FuelPump @relation(fields: [pumpId], references: [id])
  shiftId     String?
  openingReading Float  @default(0) // litres at start
  closingReading Float  @default(0) // litres at end
  litresSold  Float    @default(0)
  amount      Float    @default(0)
  readingDate DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId, pumpId])
  @@map("fuel_meter_readings")
}

model FuelShiftReport {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  shiftNo       String
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  pumpId        String?
  pump          FuelPump? @relation(fields: [pumpId], references: [id])
  openingReading Float  @default(0)
  closingReading Float  @default(0)
  litresSold    Float    @default(0)
  cashSales     Float    @default(0)
  mobileSales   Float    @default(0)
  creditSales   Float    @default(0)
  totalSales    Float    @default(0)
  lubricantSales Float   @default(0)
  carWashIncome Float    @default(0)
  expenses      Float    @default(0)
  netAmount     Float    @default(0)
  startDate     DateTime
  endDate       DateTime?
  status        String   @default("open") // open, closed, reconciled
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, shiftNo])
  @@index([tenantId, branchId])
  @@map("fuel_shift_reports")
}

model FuelDipstickReading {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  tankId       String
  tank         FuelTank @relation(fields: [tankId], references: [id])
  readingDate  DateTime @default(now())
  dipstickLevel Float   @default(0) // physical litres measured by dipstick
  bookStock    Float    @default(0) // system book stock at time of reading
  variance     Float    @default(0) // dipstickLevel - bookStock
  attendant    String?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([tenantId, tankId])
  @@map("fuel_dipstick_readings")
}

model FuelPricing {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  fuelType      String   // petrol, diesel, kerosene, gas
  pumpPrice     Float    @default(0) // selling price per litre
  costPrice     Float    @default(0) // cost per litre
  margin        Float    @default(0) // pumpPrice - costPrice
  effectiveDate DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())

  @@index([tenantId, fuelType])
  @@map("fuel_pricing")
}

model FuelCompliance {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  inspectionDate DateTime @default(now())
  type          String   // e.g. environmental, safety, calibration
  result        String   // pass, fail, pending
  nextDue       DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("fuel_compliance")
}

// =====================================================
// MANUFACTURING MODULE
// =====================================================

model ProductionOrder {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orderNo       String
  productId     String   // the finished good to produce
  product       Product  @relation(fields: [productId], references: [id])
  recipeId      String?  // linked BOM/Recipe
  recipe        Recipe?  @relation(fields: [recipeId], references: [id])
  quantity      Float    @default(0) // units to produce (planned)
  actualQuantity Float   @default(0) // actual units produced
  unitCost      Float    @default(0) // material cost per unit
  laborCost     Float    @default(0) // labor cost total
  overheadCost  Float    @default(0) // overhead cost total
  standardCost  Float    @default(0) // expected total cost (BOM-based)
  actualCost    Float    @default(0) // actual total cost (material + labor + overhead + waste)
  totalCost     Float    @default(0) // legacy field — kept for backward compat
  wasteQty      Float    @default(0)
  expectedYield Float    @default(0) // expected output quantity
  actualYield   Float    @default(0) // actual output quantity
  batchNumber   String?  // production batch/lot number
  qualityStatus String   @default("pending") // pending, passed, failed, rework
  qualityNotes  String?
  qualityCheckedBy String?
  qualityCheckedAt DateTime?
  status        String   @default("pending") // pending, in_progress, completed, cancelled
  startDate     DateTime?
  endDate       DateTime?
  plannedStartDate DateTime? // scheduled start
  plannedEndDate   DateTime? // scheduled end
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wasteRecords  ProductionWaste[]
  qualityChecks QualityCheck[]
  batches       ProductionBatch[]

  @@unique([tenantId, orderNo])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([tenantId, qualityStatus])
  @@map("production_orders")
}

model ProductionWaste {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId     String?  // wasted ingredient (if applicable)
  product       Product? @relation(fields: [productId], references: [id])
  quantity      Float    @default(0)
  unitCost      Float    @default(0)
  totalCost     Float    @default(0)
  reason        String?
  createdAt     DateTime @default(now())

  @@index([tenantId, productionOrderId])
  @@map("production_waste")
}

model QualityCheck {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  checkType       String   // incoming_material, in_process, final_inspection
  status          String   @default("pending") // pending, passed, failed, rework
  checkedBy       String?
  checkedAt       DateTime?
  notes           String?
  defectQty       Float    @default(0)
  defectDescription String?
  createdAt       DateTime @default(now())

  @@index([tenantId, productionOrderId])
  @@index([tenantId, status])
  @@map("quality_checks")
}

model ProductionBatch {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  batchNumber     String
  quantity        Float    @default(0)
  manufacturedDate DateTime @default(now())
  expiryDate      DateTime?
  status          String   @default("active") // active, quarantined, recalled, expired
  notes           String?
  createdAt       DateTime @default(now())

  @@unique([tenantId, batchNumber])
  @@index([tenantId, productionOrderId])
  @@index([tenantId, status])
  @@map("production_batches")
}

// =====================================================
// AGRICULTURE MODULE
// =====================================================

model FarmField {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "North Field", "Paddock A"
  areaSize    Float    @default(0) // acres/hectares
  areaUnit    String   @default("acre") // acre, hectare
  cropType    String?  // current crop
  status      String   @default("active") // active, fallow, harvested
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  harvests    Harvest[]
  fieldExpenses FarmExpense[]

  @@index([tenantId, branchId])
  @@map("farm_fields")
}

model Livestock {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String   // "Cattle Herd", "Poultry House 1"
  type        String   // cattle, poultry, goats, sheep, pigs, fish
  breed       String?
  count       Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  harvests    Harvest[]
  expenses    FarmExpense[]

  @@index([tenantId, branchId])
  @@map("livestock")
}

model Harvest {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  fieldId     String?
  field       FarmField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  livestockId String?
  livestock   Livestock? @relation(fields: [livestockId], references: [id], onDelete: SetNull)
  type        String   // crop, milk, eggs, meat
  productName String?  // e.g. "Maize", "Milk", "Eggs"
  productId   String?  // linked inventory product (harvest increases stock)
  product     Product? @relation(fields: [productId], references: [id])
  quantity    Float    @default(0)
  unit        String   @default("kg") // kg, litres, trays, bags
  quality     String?  // grade A, grade B, etc.
  harvestDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("harvests")
}

model FarmExpense {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  fieldId     String?
  field       FarmField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  livestockId String?
  livestock   Livestock? @relation(fields: [livestockId], references: [id], onDelete: SetNull)
  category    String   // seeds, fertilizer, feed, veterinary, labour, fuel, irrigation
  description String
  amount      Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("farm_expenses")
}

// =====================================================
// SERVICE ENGINE (Appointments, Work Orders, Contracts)
// =====================================================

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String
  customerPhone String?
  customerEmail String?
  productId   String?  // service item
  product     Product? @relation(fields: [productId], references: [id])
  technicianId String? // assigned user/staff
  technician  User?    @relation("AppointmentTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  title       String
  description String?
  scheduledDate DateTime
  scheduledTime String  // "09:30"
  endTime     String?   // "10:30"
  duration    String?   // "1 hour", "30 min"
  status      String   @default("scheduled") // scheduled, confirmed, in_progress, completed, cancelled, no_show
  price       Float    @default(0)
  actualPrice Float    @default(0) // final price after completion
  notes       String?
  reminderSent Boolean @default(false) // SMS/email reminder sent
  completedAt DateTime?
  cancelledReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobCards    ServiceJobCard[]
  feedback    ServiceFeedback[]

  @@index([tenantId, scheduledDate])
  @@index([tenantId, technicianId])
  @@index([tenantId, status])
  @@map("appointments")
}

model WorkOrder {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orderNo     String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String
  customerPhone String?
  customerEmail String?
  productId   String?  // service item
  product     Product? @relation(fields: [productId], references: [id])
  technicianId String?
  technician  User?    @relation("WorkOrderTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String   @default("open") // open, in_progress, on_hold, completed, cancelled
  priority    String   @default("normal") // low, normal, high, urgent
  serviceCategory String? // e.g., "repair", "installation", "maintenance", "consultation"
  estimatedCost Float  @default(0)
  actualCost  Float    @default(0)
  laborCost   Float    @default(0)
  partsCost   Float    @default(0)
  startDate   DateTime?
  endDate     DateTime?
  diagnostics String?  // technician diagnosis notes
  warrantyInfo String? // warranty details for the work done
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobCards    ServiceJobCard[]
  feedback    ServiceFeedback[]

  @@unique([tenantId, orderNo])
  @@index([tenantId, branchId])
  @@index([tenantId, technicianId])
  @@index([tenantId, status])
  @@map("work_orders")
}

model ServiceContract {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  contractNo  String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  title       String
  description String?
  serviceCategory String? // e.g., "maintenance", "consulting", "cleaning", "IT support"
  startDate   DateTime
  endDate     DateTime?
  renewalDate DateTime? // auto-renewal date if applicable
  autoRenew   Boolean  @default(false)
  nextBillingDate DateTime? // upcoming billing date
  value       Float    @default(0)
  billingCycle String  @default("monthly") // one_time, monthly, quarterly, yearly
  discountPercent Float @default(0) // loyalty discount
  status      String   @default("active") // active, expired, terminated, cancelled, pending_renewal
  terms       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feedback    ServiceFeedback[]

  @@unique([tenantId, contractNo])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@map("service_contracts")
}

// Dedicated Car Wash records (optional, new)
model CarWashRecord {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  vehicle     String
  serviceType String
  amount      Float    @default(0)
  attendantId String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, branchId])
  @@map("car_wash_records")
}

// Dedicated Garage service records (optional, new)
model GarageService {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  vehicle     String
  service     String
  cost        Float    @default(0)
  attendantId String?
  status      String   @default("open")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, branchId])
  @@map("garage_services")
}

// =====================================================
// SERVICE TECHNICIANS (staff profiles with skills & ratings)
// =====================================================

model ServiceTechnician {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userId      String?  // linked system user (optional)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  email       String?
  phone       String?
  role        String   @default("technician") // technician, specialist, senior_technician, supervisor
  skills      String[] @default([]) // e.g., ["electrical", "plumbing", "HVAC", "hair styling"]
  specializations String[] @default([]) // e.g., ["bridal makeup", "color treatment", "engine repair"]
  hourlyRate  Float    @default(0)
  availability String  @default("full_time") // full_time, part_time, on_call, unavailable
  rating      Float    @default(0) // average rating from feedback
  totalJobs   Int      @default(0)
  completedJobs Int    @default(0)
  isActive    Boolean  @default(true)
  hireDate    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobCards    ServiceJobCard[]

  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
  @@map("service_technicians")
}

// =====================================================
// SERVICE JOB CARDS (detailed work tracking with time & parts)
// =====================================================

model ServiceJobCard {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  cardNo      String
  appointmentId String?
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  workOrderId  String?
  workOrder    WorkOrder?   @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  technicianId String?
  technician  ServiceTechnician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  customerName String
  customerPhone String?
  serviceTitle String
  serviceDescription String?
  status      String   @default("pending") // pending, in_progress, on_hold, completed, cancelled
  priority    String   @default("normal") // low, normal, high, urgent
  // Time tracking
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  laborHours   Float    @default(0)
  // Cost tracking
  laborCost    Float    @default(0)
  partsCost    Float    @default(0)
  totalCost    Float    @default(0)
  // Parts used (JSON array: [{ name, quantity, unitCost, totalCost }])
  partsUsed    Json?
  // Quality & completion
  qualityCheckPassed Boolean @default(false)
  qualityNotes String?
  completionNotes String?
  customerSignature String? // base64 or URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, cardNo])
  @@index([tenantId, branchId])
  @@index([tenantId, technicianId])
  @@index([tenantId, status])
  @@map("service_job_cards")
}

// =====================================================
// SERVICE FEEDBACK (customer ratings & reviews)
// =====================================================

model ServiceFeedback {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  appointmentId String?
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  workOrderId  String?
  workOrder    WorkOrder?   @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  contractId   String?
  contract     ServiceContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String
  customerPhone String?
  rating       Int      @default(5) // 1-5 stars
  serviceQuality Int   @default(5) // 1-5
  timeliness   Int      @default(5) // 1-5
  professionalism Int  @default(5) // 1-5
  valueForMoney Int    @default(5) // 1-5
  comment      String?
  wouldRecommend Boolean @default(true)
  status       String   @default("published") // published, hidden, flagged
  response     String?  // business response to feedback
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, branchId])
  @@index([tenantId, rating])
  @@index([tenantId, createdAt])
  @@map("service_feedback")
}

// =====================================================
// ASSET & RESOURCE ENGINE (generic assets)
// =====================================================

model Asset {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name        String
  assetType   String   // machine, vehicle, equipment, building, land
  category    String?  // sub-category
  serialNo    String?
  purchaseDate DateTime?
  purchaseCost Float   @default(0)
  currentValue Float   @default(0)
  status      String   @default("active") // active, maintenance, retired, sold
  assignedTo  String?  // user or location
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, branchId])
  @@map("assets")
}

// =====================================================
// TAX PAYMENTS
// =====================================================

model TaxPayment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  amount        Float
  currency      String   @default("USD")
  periodFrom    DateTime?
  periodTo      DateTime?
  prn           String?
  paymentMethod String   @default("cash")
  dateOfPayment DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId, branchId])
  @@map("tax_payments")
}

// =====================================================
// USER GUIDE STEPS — SaaS admin manages step-by-step guides with images
// =====================================================

model UserGuideStep {
  id          String   @id @default(cuid())
  category    String   // e.g. "sales", "inventory", "branches", "staff"
  stepNumber  Int      // order within category
  title       String
  description String
  imageUrl    String?  // Cloudinary URL
  imagePublicId String? // Cloudinary public_id for deletion
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, stepNumber])
  @@map("user_guide_steps")
}

// =====================================================
// PUSH NOTIFICATION TOKENS (FCM)
// =====================================================

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform  String   @default("web") // web, android, ios
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("push_tokens")
}

// =====================================================
// WIDGET DATA — Sticky Notes & Calculator History
// =====================================================

model StickyNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title     String   @default("")
  content   String   @default("")
  mode      String   @default("plain") // plain, numbered, tasks
  tasks     Json     @default("[]") // [{ id, text, done }]
  color     String   @default("yellow")
  pinned    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("sticky_notes")
}

model CalculatorHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  history   Json     @default("[]") // [{ expression, result, timestamp }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@map("calculator_history")
}
