    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "nodemailer": "^7.0.6",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.0",
    "prisma": "^5.22.0",
    "resend": "^6.12.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
