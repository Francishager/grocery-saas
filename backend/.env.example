# Frontend URL (for CORS and redirects)
FRONTEND_ORIGIN=https://grocery-saas.grocerysaas.workers.dev
ALLOWED_ORIGINS=https://grocery-saas.grocerysaas.workers.dev,https://grocery-saas-backend.up.railway.app

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/grocery_saas"

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters

# Server Configuration
PORT=3000
NODE_ENV=production

# Email Configuration (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@example.com

# Feature Flags
ENABLE_SEED=false
OBFUSCATE_ADMIN=false