# Grist Configuration
GRIST_API_KEY=your_grist_api_key
GRIST_DOC_ID=your_grist_doc_id

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS and redirects)
FRONTEND_ORIGIN=https://your-frontend.pages.dev
ALLOWED_ORIGINS=https://your-frontend.pages.dev,https://your-backend.railway.app

# Email Configuration (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@example.com

# Feature Flags
ENABLE_SEED=false
OBFUSCATE_ADMIN=false

# Table Names (defaults shown)
USERS_TABLE=Users
BUSINESSES_TABLE=Businesses
SUBSCRIPTIONS_TABLE=Subscription
INVITATIONS_TABLE=Invitations
TENANTS_TABLE=Tenants
PLANS_TABLE=Plans
